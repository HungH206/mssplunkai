<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:uipath="http://uipath.org/schema/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="x-uipath-initial-diagram" targetNamespace="http://www.omg.org/spec/BPMN/20100524/MODEL" exporter="UiPath Studio Web (https://uipath.com)" exporterVersion="b52d90e7">
  <bpmn:process id="Process_1" name="Process" isExecutable="false">
    <bpmn:extensionElements>
      <uipath:variables version="v1">
        <uipath:inputOutput id="scriptResponse" name="scriptResponse" type="jsonSchema" elementId="task_set_variables" />
        <uipath:inputOutput id="error" name="Error" type="jsonSchema" elementId="task_set_variables"><![CDATA[{"type":"object","properties":{"code":{"type":"string"},"message":{"type":"string"},"detail":{"type":"string"},"category":{"type":"string"},"status":{"type":"number"},"element":{"type":"string"}}}]]></uipath:inputOutput>
      </uipath:variables>
      <uipath:migrationVersion version="15" />
      <uipath:intsvcActivityConfig version="v2" />
    </bpmn:extensionElements>
    <bpmn:startEvent id="start_event" name="Start">
      <bpmn:extensionElements>
        <uipath:entryPointId value="9271c647-aa5f-4a25-8183-913c3e35f543" />
      </bpmn:extensionElements>
      <bpmn:outgoing>flow_start_to_create_case</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="task_create_case" name="Create Certification Case">
      <bpmn:incoming>flow_start_to_create_case</bpmn:incoming>
      <bpmn:outgoing>flow_create_case_to_gateway</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gateway_existing_plan" name="Existing Plan?" default="flow_existing_plan_no">
      <bpmn:incoming>flow_create_case_to_gateway</bpmn:incoming>
      <bpmn:outgoing>flow_existing_plan_yes</bpmn:outgoing>
      <bpmn:outgoing>flow_existing_plan_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="task_resume_case" name="Resume Case">
      <bpmn:incoming>flow_existing_plan_yes</bpmn:incoming>
      <bpmn:outgoing>flow_resume_to_end</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="task_learning_agent" name="Learning Agent">
      <bpmn:incoming>flow_existing_plan_no</bpmn:incoming>
      <bpmn:outgoing>flow_learning_agent_to_save</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_save_learning_plan" name="Save Learning Plan">
      <bpmn:incoming>flow_learning_agent_to_save</bpmn:incoming>
      <bpmn:outgoing>flow_save_plan_to_planner</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_planner_agent" name="Planner Agent">
      <bpmn:incoming>flow_save_plan_to_planner</bpmn:incoming>
      <bpmn:outgoing>flow_planner_to_save_study</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_save_study_plan" name="Save Study Plan">
      <bpmn:incoming>flow_planner_to_save_study</bpmn:incoming>
      <bpmn:outgoing>flow_save_study_to_assess</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_assessment_agent" name="Assessment Agent">
      <bpmn:incoming>flow_save_study_to_assess</bpmn:incoming>
      <bpmn:incoming>flow_reassess_to_assessment_loop</bpmn:incoming>
      <bpmn:outgoing>flow_assess_to_save_assess</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_save_assessment" name="Save Assessment">
      <bpmn:incoming>flow_assess_to_save_assess</bpmn:incoming>
      <bpmn:outgoing>flow_save_assess_to_risk</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_risk_agent" name="Risk Agent">
      <bpmn:incoming>flow_save_assess_to_risk</bpmn:incoming>
      <bpmn:outgoing>flow_risk_to_ready_gateway</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gateway_ready" name="Ready?" default="flow_ready_no">
      <bpmn:incoming>flow_risk_to_ready_gateway</bpmn:incoming>
      <bpmn:outgoing>flow_ready_no</bpmn:outgoing>
      <bpmn:outgoing>flow_ready_yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="task_manager_review" name="Manager Review">
      <bpmn:incoming>flow_ready_no</bpmn:incoming>
      <bpmn:outgoing>flow_review_to_approved_gateway</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="gateway_approved" name="Approved?" default="flow_approved_no">
      <bpmn:incoming>flow_review_to_approved_gateway</bpmn:incoming>
      <bpmn:outgoing>flow_approved_no</bpmn:outgoing>
      <bpmn:outgoing>flow_approved_yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_coaching_agent" name="Coaching Agent">
      <bpmn:incoming>flow_approved_no</bpmn:incoming>
      <bpmn:outgoing>flow_coaching_to_update</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_update_study_plan" name="Update Study Plan">
      <bpmn:incoming>flow_coaching_to_update</bpmn:incoming>
      <bpmn:outgoing>flow_update_to_reassess</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_reassessment" name="Reassessment">
      <bpmn:incoming>flow_update_to_reassess</bpmn:incoming>
      <bpmn:outgoing>flow_reassess_to_assessment_loop</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="end_event_complete" name="Complete">
      <bpmn:incoming>flow_resume_to_end</bpmn:incoming>
      <bpmn:incoming>flow_ready_yes</bpmn:incoming>
      <bpmn:incoming>flow_approved_yes</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="flow_create_case_to_gateway" sourceRef="task_create_case" targetRef="gateway_existing_plan" />
    <bpmn:sequenceFlow id="flow_existing_plan_yes" name="Yes" sourceRef="gateway_existing_plan" targetRef="task_resume_case">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=${existingPlan == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_existing_plan_no" name="No" sourceRef="gateway_existing_plan" targetRef="task_learning_agent" />
    <bpmn:sequenceFlow id="flow_learning_agent_to_save" sourceRef="task_learning_agent" targetRef="task_save_learning_plan" />
    <bpmn:sequenceFlow id="flow_save_plan_to_planner" sourceRef="task_save_learning_plan" targetRef="task_planner_agent" />
    <bpmn:sequenceFlow id="flow_planner_to_save_study" sourceRef="task_planner_agent" targetRef="task_save_study_plan" />
    <bpmn:sequenceFlow id="flow_save_study_to_assess" sourceRef="task_save_study_plan" targetRef="task_assessment_agent" />
    <bpmn:sequenceFlow id="flow_assess_to_save_assess" sourceRef="task_assessment_agent" targetRef="task_save_assessment" />
    <bpmn:sequenceFlow id="flow_save_assess_to_risk" sourceRef="task_save_assessment" targetRef="task_risk_agent" />
    <bpmn:sequenceFlow id="flow_risk_to_ready_gateway" sourceRef="task_risk_agent" targetRef="gateway_ready" />
    <bpmn:sequenceFlow id="flow_ready_no" name="No" sourceRef="gateway_ready" targetRef="task_manager_review" />
    <bpmn:sequenceFlow id="flow_review_to_approved_gateway" sourceRef="task_manager_review" targetRef="gateway_approved" />
    <bpmn:sequenceFlow id="flow_approved_no" name="No" sourceRef="gateway_approved" targetRef="task_coaching_agent" />
    <bpmn:sequenceFlow id="flow_coaching_to_update" sourceRef="task_coaching_agent" targetRef="task_update_study_plan" />
    <bpmn:sequenceFlow id="flow_update_to_reassess" sourceRef="task_update_study_plan" targetRef="task_reassessment" />
    <bpmn:sequenceFlow id="flow_reassess_to_assessment_loop" sourceRef="task_reassessment" targetRef="task_assessment_agent" />
    <bpmn:sequenceFlow id="flow_resume_to_end" sourceRef="task_resume_case" targetRef="end_event_complete" />
    <bpmn:sequenceFlow id="flow_ready_yes" name="Yes" sourceRef="gateway_ready" targetRef="end_event_complete">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=${isReady == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_approved_yes" name="Yes" sourceRef="gateway_approved" targetRef="end_event_complete">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=${approved == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_start_to_create_case" sourceRef="start_event" targetRef="task_create_case" />
  </bpmn:process>
