{
  "version": "1.1.0",
  "settings": {
    "model": "gpt-5.4",
    "maxTokens": 128000,
    "temperature": 0,
    "engine": "basic-v2",
    "maxIterations": 25,
    "mode": "standard"
  },
  "inputSchema": {
    "type": "object",
    "properties": {
      "learnerId": {
        "type": "string",
        "description": "Unique identifier of the learner. Passed through from PlannerAgent output for traceability. Must be non-empty."
      },
      "certificationId": {
        "type": "string",
        "description": "Unique identifier of the certification. Passed through for traceability. Must be non-empty."
      },
      "certificationName": {
        "type": "string",
        "description": "Human-readable name of the certification (e.g., 'AWS Solutions Architect'). Used to contextualize the assessment."
      },
      "learnerProfile": {
        "type": "object",
        "description": "Learner background profile. Contains: name (string), role (string), department (string), experienceLevel (beginner/intermediate/advanced), previousCertifications (array of strings).",
        "properties": {
          "name": {
            "type": "string",
            "description": "Full name of the learner."
          },
          "role": {
            "type": "string",
            "description": "Current job role."
          },
          "department": {
            "type": "string",
            "description": "Department of the learner."
          },
          "experienceLevel": {
            "type": "string",
            "enum": [
              "beginner",
              "intermediate",
              "advanced"
            ],
            "description": "Experience level in the certification domain."
          },
          "previousCertifications": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Previously completed certifications."
          }
        }
      },
      "studyPlan": {
        "type": "object",
        "description": "The personalized study plan generated by the PlannerAgent. Contains weeklyMilestones, checkpoints, dailyStudyHours, and recommendedResources.",
        "properties": {
          "title": {
            "type": "string",
            "description": "Title of the study plan."
          },
          "startDate": {
            "type": "string",
            "description": "Study start date in YYYY-MM-DD."
          },
          "targetExamDate": {
            "type": "string",
            "description": "Target exam date in YYYY-MM-DD."
          },
          "dailyStudyHours": {
            "type": "number",
            "description": "Recommended daily study hours."
          },
          "weeklyMilestones": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "description": "Week-by-week study milestones."
          },
          "checkpoints": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "description": "Readiness checkpoints with target percentages."
          }
        }
      },
      "quizResults": {
        "type": "array",
        "description": "Optional array of prior quiz or practice exam results. Each item: { topic (string), score (number 0-100), dateTaken (YYYY-MM-DD) }. Omit if no prior results exist.",
        "items": {
          "type": "object",
          "properties": {
            "topic": {
              "type": "string",
              "description": "Topic area of the quiz."
            },
            "score": {
              "type": "number",
              "description": "Score as a percentage (0-100)."
            },
            "dateTaken": {
              "type": "string",
              "description": "Date the quiz was taken in YYYY-MM-DD format."
            }
          }
        }
      }
    },
    "required": [
      "learnerId",
      "certificationId",
      "certificationName",
      "learnerProfile",
      "studyPlan"
    ]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "content": {
        "type": "string",
        "description": "Output content"
      }
    }
  },
  "metadata": {
    "storageVersion": "50.0.0",
    "isConversational": false,
    "showProjectCreationExperience": false,
    "targetRuntime": "pythonAgent"
  },
  "type": "lowCode",
